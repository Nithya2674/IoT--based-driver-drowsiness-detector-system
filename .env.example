# ===== MongoDB Atlas =====
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/drowsiness_db?retryWrites=true&w=majority
MONGO_DB_NAME=drowsiness_db

# ===== JWT Secret =====
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ACCESS_TOKEN_EXPIRES=3600

# ===== Flask =====
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_PORT=5000

# ===== ThingSpeak (Simulation) =====
THINGSPEAK_API_KEY=YOUR_THINGSPEAK_WRITE_API_KEY
THINGSPEAK_CHANNEL_ID=YOUR_CHANNEL_ID
THINGSPEAK_READ_API_KEY=YOUR_THINGSPEAK_READ_API_KEY

# ===== IoT Device =====
DEVICE_API_KEY=your-device-api-key
BACKEND_URL=http://localhost:5000

# ===== Security =====
ENCRYPTION_KEY=your-32-byte-encryption-key-here
